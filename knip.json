{
  "$schema": "https://knip.dev/schema-json.json",
  "paths": {
    "#core/*": ["packages/core/src/*"],
    "#full-editor/*": ["apps/full-editor-demo/src/*"],
    "#html-media-adapter/*": ["packages/html-media-adapter/src/*"],
    "#mediabunny-adapter/*": ["packages/mediabunny-adapter/src/*"],
    "#react/*": ["packages/react/src/*"],
    "#renderer/*": ["packages/renderer/src/*"],
    "#test-utils/*": ["test-utils/*"],
    "#timeline/*": ["packages/timeline/src/*"],
    "#utils/*": ["packages/utils/src/*"],
    "#www/*": ["apps/www/src/*"],
    "#www-generated/*": ["apps/www/.generated/*"],
    "@techsquidtv/canvas-timeline-renderer/*": ["packages/renderer/src/*"]
  },
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    ".": {
      "entry": ["tools/oxlint-plugin/index.mjs"],
      "project": ["*.{js,ts}", "test-utils/**/*.ts", "tools/**/*.mjs"],
      "ignoreDependencies": ["@arethetypeswrong/cli"]
    },
    "scripts": {
      "entry": [
        "checks/package-coverage.mjs",
        "checks/publishable-packages.mjs",
        "checks/consumer-smoke.mjs",
        "checks/repository-policy.mjs"
      ],
      "project": ["**/*.{mjs,ts}"]
    },
    "apps/www": {
      "project": ["scripts/**/*.mjs", "src/**/*.{ts,tsx,astro,mdx,mjs}"],
      "ignoreDependencies": ["@fontsource-variable/outfit", "tailwindcss", "typedoc", "workerd"]
    },
    "apps/full-editor-demo": {
      "entry": ["public/sw.js", "src/features/timeline/source-clip-factory.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "packages/utils": {
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "paths": {
        "#core/*": ["src/*"],
        "#test-utils/*": ["../../test-utils/*"]
      },
      "project": ["src/**/*.ts"]
    },
    "packages/react": {
      "paths": {
        "#test-utils/*": ["../../test-utils/*"],
        "#react/*": ["src/*"]
      },
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/html-media-adapter": {
      "paths": {
        "#html-media-adapter/*": ["src/*"]
      },
      "project": ["src/**/*.ts"]
    },
    "packages/mediabunny-adapter": {
      "paths": {
        "#mediabunny-adapter/*": ["src/*"]
      },
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/renderer": {
      "entry": ["src/worker.ts", "src/renderTimeline.ts", "src/render/**/*.{ts,tsx}"],
      "paths": {
        "#renderer/*": ["src/*"]
      },
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/timeline": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignoreIssues": {
    "apps/www/src/lib/metrics.ts": ["exports"],
    "packages/react/src/components/controls/RangeSelector.tsx": ["exports"],
    "packages/react/src/components/scrollbars/VerticalScrollbar.tsx": ["exports"],
    "packages/react/src/components/scrollbars/ViewportScrollbar.tsx": ["exports"],
    "packages/react/src/timecodeField/TimecodeField.tsx": ["exports"],
    "packages/react/src/hooks/core/timelineScalarControlProps.ts": ["types"],
    "packages/renderer/src/render/geometry.ts": ["exports"],
    "packages/renderer/src/render/types.ts": ["types"]
  }
}
