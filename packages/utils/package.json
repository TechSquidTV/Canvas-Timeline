{
  "name": "@techsquidtv/canvas-timeline-utils",
  "version": "0.0.1",
  "license": "MPL-2.0",
  "description": "Shared rational time and math utilities for Canvas Timeline libraries.",
  "type": "module",
  "author": "TechSquidTV",
  "bugs": {
    "url": "https://github.com/techsquidtv/canvas-timeline/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://canvastimeline.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/techsquidtv/canvas-timeline.git",
    "directory": "packages/utils"
  },
  "keywords": [
    "timeline",
    "video-editor",
    "timecode",
    "rational-time",
    "canvas-timeline"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./math": {
      "types": "./dist/math.d.mts",
      "import": "./dist/math.mjs"
    },
    "./time": {
      "types": "./dist/time.d.mts",
      "import": "./dist/time.mjs"
    },
    "./timecode": {
      "types": "./dist/timecode.d.mts",
      "import": "./dist/timecode.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch --no-clean",
    "clean": "rm -rf dist"
  }
}
