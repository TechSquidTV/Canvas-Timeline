{
  "name": "@techsquidtv/canvas-timeline",
  "version": "0.0.1",
  "license": "MPL-2.0",
  "description": "React timeline editing toolkit for Canvas Timeline.",
  "type": "module",
  "author": "TechSquidTV",
  "bugs": {
    "url": "https://github.com/techsquidtv/canvas-timeline/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://canvastimeline.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/techsquidtv/canvas-timeline.git",
    "directory": "packages/timeline"
  },
  "keywords": [
    "timeline",
    "timeline-editor",
    "react",
    "canvas",
    "offscreen-canvas",
    "video-editor",
    "canvas-timeline"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#timeline/*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.mts",
      "import": "./dist/core.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "import": "./dist/react.mjs"
    },
    "./html-media": {
      "types": "./dist/html-media.d.mts",
      "import": "./dist/html-media.mjs"
    },
    "./renderer": {
      "types": "./dist/renderer.d.mts",
      "import": "./dist/renderer.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./base.css": "./dist/base.css",
    "./theme.css": "./dist/theme.css",
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vp pack && cp src/base.css dist/base.css && cp src/theme.css dist/theme.css && cp src/styles.css dist/styles.css",
    "dev": "vp pack --watch --no-clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@techsquidtv/canvas-timeline-core": "workspace:*",
    "@techsquidtv/canvas-timeline-html-media-adapter": "workspace:*",
    "@techsquidtv/canvas-timeline-react": "workspace:*",
    "@techsquidtv/canvas-timeline-renderer": "workspace:*",
    "@techsquidtv/canvas-timeline-utils": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  }
}
