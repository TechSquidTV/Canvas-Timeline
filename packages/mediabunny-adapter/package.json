{
  "name": "@techsquidtv/canvas-timeline-mediabunny-adapter",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "description": "Mediabunny adapter for Canvas Timeline media playback and frame access.",
  "type": "module",
  "author": "TechSquidTV",
  "bugs": {
    "url": "https://github.com/techsquidtv/canvas-timeline/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://canvastimeline.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/techsquidtv/canvas-timeline.git",
    "directory": "packages/mediabunny-adapter"
  },
  "keywords": [
    "timeline",
    "video-editor",
    "mediabunny",
    "canvas-timeline"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#mediabunny-adapter/*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "import": "./dist/react.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch --no-clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@techsquidtv/canvas-timeline-core": "workspace:*",
    "@techsquidtv/canvas-timeline-react": "workspace:*",
    "@techsquidtv/canvas-timeline-utils": "workspace:*"
  },
  "peerDependencies": {
    "mediabunny": "^1.50.3",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "mediabunny": "^1.50.8",
    "react": "^19.2.7"
  }
}
