{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "resolveJsonModule": true,
    "paths": {
      "#core/*": ["../../packages/core/src/*"],
      "#full-editor/*": ["../full-editor-demo/src/*"],
      "#html-media-adapter/*": ["../../packages/html-media-adapter/src/*"],
      "#mediabunny-adapter/*": ["../../packages/mediabunny-adapter/src/*"],
      "#react/*": ["../../packages/react/src/*"],
      "#renderer/*": ["../../packages/renderer/src/*"],
      "#test-utils/*": ["../../test-utils/*"],
      "#timeline/*": ["../../packages/timeline/src/*"],
      "#utils/*": ["../../packages/utils/src/*"],
      "#www/*": ["./src/*"],
      "#www-generated/*": ["./.generated/*"],
      "@techsquidtv/canvas-timeline-core": ["../../packages/core/src/index.ts"],
      "@techsquidtv/canvas-timeline-core/*": ["../../packages/core/src/*"],
      "@techsquidtv/canvas-timeline-react": ["../../packages/react/src/index.ts"],
      "@techsquidtv/canvas-timeline-react/range-scrollbar": [
        "../../packages/react/src/rangeScrollbar/index.ts"
      ],
      "@techsquidtv/canvas-timeline-react/timecode-field": [
        "../../packages/react/src/timecodeField/index.ts"
      ],
      "@techsquidtv/canvas-timeline-react/timecode-input": [
        "../../packages/react/src/timecodeInput/index.ts"
      ],
      "@techsquidtv/canvas-timeline-react/*": ["../../packages/react/src/*"],
      "@techsquidtv/canvas-timeline-html-media-adapter": [
        "../../packages/html-media-adapter/src/index.ts"
      ],
      "@techsquidtv/canvas-timeline-html-media-adapter/*": [
        "../../packages/html-media-adapter/src/*"
      ],
      "@techsquidtv/canvas-timeline-mediabunny-adapter": [
        "../../packages/mediabunny-adapter/src/index.ts"
      ],
      "@techsquidtv/canvas-timeline-mediabunny-adapter/*": [
        "../../packages/mediabunny-adapter/src/*"
      ],
      "@techsquidtv/canvas-timeline-renderer": ["../../packages/renderer/src/index.ts"],
      "@techsquidtv/canvas-timeline-renderer/*": ["../../packages/renderer/src/*"],
      "@techsquidtv/canvas-timeline-utils": ["../../packages/utils/src/index.ts"],
      "@techsquidtv/canvas-timeline-utils/*": ["../../packages/utils/src/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
