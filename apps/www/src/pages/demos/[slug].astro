---
import BaseLayout from '#www/layouts/BaseLayout.astro';
import { demoDocs, type DemoDoc } from '#www/data/demos';
import { demoCodeExamples } from '#www/data/demo-code';
import CodeExampleTabs from '#www/components/CodeExampleTabs.astro';
import LiveDemoRenderer from '#www/components/LiveDemoRenderer';
import { createDemoStructuredData } from '#www/lib/structured-data';

interface Props {
  demoDoc: DemoDoc;
}

export function getStaticPaths() {
  return demoDocs
    .filter((demoDoc) => demoDoc.liveDemoId)
    .map((demoDoc) => ({
      params: { slug: demoDoc.slug },
      props: { demoDoc },
    }));
}

const { demoDoc } = Astro.props;
const codeExample = demoDoc.liveDemoId ? demoCodeExamples[demoDoc.liveDemoId] : undefined;
const hasAsideLinks = Boolean(demoDoc.externalUrl || demoDoc.references?.length);
const sourceUrl = `https://github.com/techsquidtv/canvas-timeline/blob/main/${demoDoc.sourcePath}`;
const sourceFileName = demoDoc.sourcePath.split('/').pop() ?? demoDoc.sourcePath;
const structuredData = createDemoStructuredData(demoDoc);
---

<BaseLayout
  title={demoDoc.title}
  description={demoDoc.description}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Demos', href: '/demos' },
    { label: demoDoc.title },
  ]}
  structuredData={structuredData}
>
  <section class="page-band">
    <div class="container-page page-heading">
      <p class="eyebrow">Demo</p>
      <h1>{demoDoc.title}</h1>
      <p>{demoDoc.description}</p>
      <div class="demo-meta-row" aria-label="Demo metadata">
        <span class="status-pill">{demoDoc.status}</span>
        <span>{demoDoc.difficulty}</span>
        <a
          class="demo-source-link"
          href={sourceUrl}
          rel="noreferrer"
          target="_blank"
          title={`View ${sourceFileName} on GitHub`}
        >
          <span>{sourceFileName}</span>
          <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.58 2 12.24c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49v-1.9c-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.1-1.49-1.1-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.95c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9v2.81c0 .27.18.59.69.49A10.22 10.22 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
  <article class={`container-page detail-layout${hasAsideLinks ? '' : ' detail-layout-full'}`}>
    <section class="detail-main">
      {
        demoDoc.liveDemoId && codeExample ? (
          <>
            <h2>Live demo</h2>
            <LiveDemoRenderer
              liveDemoId={demoDoc.liveDemoId}
              category={demoDoc.status}
              client:only="react"
            />

            <h2>Code example</h2>
            <CodeExampleTabs
              id={demoDoc.slug}
              tsx={codeExample.tsx}
              data={codeExample.data}
              css={codeExample.css}
              extraTabs={codeExample.extraTabs}
            />
          </>
        ) : null
      }
    </section>
    {
      hasAsideLinks ? (
        <aside class="detail-aside">
          <h2>Links</h2>
          {
            demoDoc.externalUrl ? (
              <a class="button button-secondary detail-button" href={demoDoc.externalUrl}>
                Open demo
              </a>
            ) : null
          }
          <div class="aside-link-list">
            {demoDoc.references?.map((reference) => (
              <a href={reference.url}>{reference.label}</a>
            ))}
          </div>
        </aside>
      ) : null
    }
  </article>
</BaseLayout>
