---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  reactRegistryGroups,
  reactRegistryItems,
  reactRegistryPackageName,
} from '@/data/react-registry';
import PackageManagerTabs from '@/components/PackageManagerTabs.astro';
import { createReactRegistryIndexStructuredData } from '@/lib/structured-data';

const structuredData = createReactRegistryIndexStructuredData(reactRegistryItems);
---

<BaseLayout
  title="React Timeline Component Registry"
  description="Browse the component registry for our React timeline component. Reusable primitives, interaction layers, and hook bindings for the canvas timeline editor."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Packages', href: '/packages' },
    { label: 'React', href: '/packages/react' },
    { label: 'Registry' },
  ]}
  structuredData={structuredData}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-background pt-12 pb-16 md:pt-16 md:pb-20 border-b border-border">
    <!-- Subtle Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[400px] bg-[radial-gradient(ellipse_at_top,var(--primary),transparent_60%)] opacity-10 pointer-events-none" aria-hidden="true"></div>

    <div class="container-page relative z-10 px-4 flex flex-col items-center text-center">
      <!-- Eyebrow -->
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold tracking-wider text-primary bg-primary/10 border border-primary/20 uppercase mb-4">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
        </svg>
        React Registry
      </span>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-foreground leading-none max-w-4xl mx-auto">
        React Timeline Components
      </h1>

      <!-- Description -->
      <p class="mt-4 text-base text-muted-foreground max-w-3xl mx-auto leading-relaxed">
        Browse the curated React surfaces for timeline interaction layers, reusable primitives, and editor controls bound to a TimelineEngine.
      </p>
    </div>
  </section>

  <!-- Main Content Layout -->
  <div class="container-page px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Main Content Column -->
      <article class="lg:col-span-8 space-y-16">
        {
          reactRegistryGroups.map((group) => (
            <section class="space-y-6 scroll-mt-24" id={group.id}>
              <div class="border-b border-border pb-4 text-left">
                <h2 class="text-xl md:text-2xl font-bold text-foreground">
                  {group.title}
                </h2>
                <p class="text-sm text-muted-foreground mt-1">
                  {group.description}
                </p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {group.items.map((item) => (
                  <a
                    class="group bg-card border border-border rounded-xl p-5 flex flex-col justify-between hover:border-primary hover:shadow-md transition-all duration-300 text-left text-decoration-none text-inherit cursor-pointer"
                    href={`/packages/react/registry/${item.slug}`}
                  >
                    <div>
                      <div class="flex items-center justify-between gap-2 mb-3">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-primary/10 text-primary">
                          {item.kind}
                        </span>
                        <code class="text-[10px] font-mono text-muted-foreground bg-muted px-1.5 py-0.5 rounded">
                          {item.importPath}
                        </code>
                      </div>
                      <strong class="block text-base font-bold text-foreground group-hover:text-primary transition-colors">
                        {item.name}
                      </strong>
                      <p class="mt-2 text-xs md:text-sm text-muted-foreground leading-relaxed">
                        {item.description}
                      </p>
                    </div>
                    <div class="mt-4 flex items-center gap-1.5 text-xs font-bold text-primary">
                      View details
                      <svg class="w-3.5 h-3.5 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))
        }
      </article>

      <!-- Sidebar Column -->
      <aside class="lg:col-span-4 space-y-6 lg:sticky lg:top-24">
        <!-- Installation Card -->
        <div class="bg-card border border-border rounded-xl p-5">
          <h3 class="text-sm font-bold text-foreground mb-2" id="registry-install-heading">Installation</h3>
          <p class="text-xs text-muted-foreground leading-relaxed mb-4">
            Add the React package once, then open a registry entry for usage, examples, and API references.
          </p>
          <PackageManagerTabs packages={reactRegistryPackageName} />
        </div>

        <!-- Quick Links Card -->
        <div class="bg-card border border-border rounded-xl p-5">
          <h3 class="text-sm font-bold text-foreground mb-3">Quick Links</h3>
          <div class="flex flex-col gap-2">
            <a href="/packages/react" class="inline-flex items-center justify-between p-2.5 rounded-lg border border-border/60 hover:border-primary/40 hover:bg-muted/10 transition-all text-xs text-foreground/80 font-medium">
              <span>React Package Docs</span>
              <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            <a href="/packages/react/api" class="inline-flex items-center justify-between p-2.5 rounded-lg border border-border/60 hover:border-primary/40 hover:bg-muted/10 transition-all text-xs text-foreground/80 font-medium">
              <span>React API Reference</span>
              <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>
