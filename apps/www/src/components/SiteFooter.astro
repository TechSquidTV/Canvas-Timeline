---
import { site } from '#www/data/site';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-page site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand-link" href="/" aria-label={`${site.name} home`}>
        <img class="brand-logo" src="/logo.svg" alt="" width="36" height="34" decoding="async" />
        <span>{site.name}</span>
      </a>
      <p>{site.description}</p>
      <p class="site-footer__copyright">&copy; {currentYear} TechSquidTV. All rights reserved.</p>
    </div>
    <nav class="site-footer__links" aria-label="Footer navigation">
      {
        site.footerGroups.map((group) => (
          <section class="site-footer__group" aria-labelledby={`footer-${group.title.toLowerCase()}`}>
            <h2 id={`footer-${group.title.toLowerCase()}`}>{group.title}</h2>
            <ul>
              {group.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </nav>
  </div>
</footer>
