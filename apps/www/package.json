{
  "name": "@techsquidtv/canvas-timeline-www",
  "private": true,
  "version": "0.0.1",
  "license": "MPL-2.0",
  "type": "module",
  "imports": {
    "#www/*": "./src/*",
    "#www-generated/*": "./.generated/*"
  },
  "scripts": {
    "dev": "vp run docs:api && astro dev --port=4321 --host=0.0.0.0",
    "build": "vp run docs:sponsors && vp run docs:api && vp run docs:demos && vp run docs:links && vp run docs:registry && vp run docs:og && vp run docs:editor && astro build && vp run docs:search && vp run docs:editor:verify",
    "preview": "astro preview --host=0.0.0.0",
    "docs:api": "node scripts/generate/api-reference.mjs",
    "docs:links": "node scripts/verify/links.mjs",
    "docs:sponsors": "tsx scripts/sponsors/sync.ts",
    "docs:demos": "node scripts/demos/verify.mjs",
    "docs:editor": "vp run --filter @techsquidtv/canvas-timeline-full-editor-demo build:docs && node scripts/demos/stage-full-editor.mjs",
    "docs:registry": "node ../../scripts/checks/react-registry.mjs",
    "docs:og": "tsx scripts/generate/open-graph.ts",
    "docs:editor:verify": "node scripts/demos/verify-full-editor-build.mjs",
    "docs:search": "tsx scripts/generate/search-catalog.ts && pagefind --site dist/client && node scripts/verify/search-build.mjs",
    "docs:demo:new": "node scripts/demos/scaffold.mjs",
    "clean": "rm -rf .astro dist .generated public/open-graph public/demos/full-editor-demo public/full-editor-demo"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.44.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@sentry/astro": "^10.65.0",
    "@sentry/cloudflare": "^10.65.0",
    "@techsquidtv/canvas-timeline-core": "workspace:*",
    "@techsquidtv/canvas-timeline-html-media-adapter": "workspace:*",
    "@techsquidtv/canvas-timeline-mediabunny-adapter": "workspace:*",
    "@techsquidtv/canvas-timeline-react": "workspace:*",
    "@techsquidtv/canvas-timeline-renderer": "workspace:*",
    "@techsquidtv/canvas-timeline-utils": "workspace:*",
    "astro": "^7.0.7",
    "astro-expressive-code": "^0.44.0",
    "astro-og-canvas": "^0.13.0",
    "canvaskit-wasm": "^0.41.1",
    "lucide-react": "^1.24.0",
    "mediabunny": "^1.50.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "rehype-expressive-code": "^0.44.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@techsquidtv/canvas-timeline-scripts": "workspace:*",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "workerd": "^1.20260710.1",
    "wrangler": "^4.110.0"
  }
}
